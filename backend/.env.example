# Application
APP_NAME=Inventory API
JWT_SECRET=replace_with_long_random_secret
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
EXPOSE_STACKTRACE=false
CORS_ALLOW_ORIGINS=https://app.example.com
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=60

# Idempotency
IDEMPOTENCY_KEY_TTL_HOURS=48

# Database (PostgreSQL)
POSTGRES_DB=inventory
POSTGRES_USER=inventory_admin
POSTGRES_PASSWORD=replace_with_strong_admin_password
APP_DB_USER=inventory_app
APP_DB_PASSWORD=replace_with_strong_app_password
DATABASE_URL=postgresql+psycopg://inventory_app:replace_with_strong_app_password@db:5432/inventory

# Backups
BACKUP_RETENTION_DAYS=14
BACKUP_RETENTION_REVISION_DAYS=90
BACKUP_RETENTION_EMERGENCY_DAYS=14
BACKUP_INTERVAL_SECONDS=86400

# S3-compatible object storage (optional — leave BACKUP_S3_BUCKET empty to disable)
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=backups/
BACKUP_S3_ENDPOINT_URL=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_REGION=us-east-1

# Migration safety guard
MIGRATION_GUARD_ENABLED=1
MIGRATION_BACKUP_CONFIRMED=0
MIGRATION_RESTORE_CHECK_CONFIRMED=0
